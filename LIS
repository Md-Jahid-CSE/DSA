//Recursive Code
#include <bits/stdc++.h>
using namespace std;

int LIS(int i, int prev, vector<int> &arr) {
    if (i == arr.size())
        return 0;

    int take = 0;
    if (prev == -1 || arr[i] > arr[prev])
        take = 1 + LIS(i + 1, i, arr);

    int notTake = LIS(i + 1, prev, arr);

    return max(take, notTake);
}

int main() {
    vector<int> arr = {10, 9, 2, 5, 3, 7, 101, 18};

    cout << LIS(0, -1, arr);

    return 0;
}

//Memoization Code
#include <bits/stdc++.h>
using namespace std;

int dp[1001][1001];

int LIS(int i, int prev, vector<int> &arr) {
    if (i == arr.size())
        return 0;

    if (dp[i][prev + 1] != -1)
        return dp[i][prev + 1];

    int take = 0;
    if (prev == -1 || arr[i] > arr[prev])
        take = 1 + LIS(i + 1, i, arr);

    int notTake = LIS(i + 1, prev, arr);

    return dp[i][prev + 1] = max(take, notTake);
}

int main() {
    memset(dp, -1, sizeof(dp));

    vector<int> arr = {10, 9, 2, 5, 3, 7, 101, 18};

    cout << LIS(0, -1, arr);

    return 0;
}

//Tabulation Code (Bottom-Up)
#include <bits/stdc++.h>
using namespace std;

int LIS(vector<int> &arr) {
    int n = arr.size();
    vector<int> dp(n, 1);

    for (int i = 0; i < n; i++) {
        for (int prev = 0; prev < i; prev++) {
            if (arr[i] > arr[prev])
                dp[i] = max(dp[i], 1 + dp[prev]);
        }
    }

    return *max_element(dp.begin(), dp.end());
}

int main() {
    vector<int> arr = {10, 9, 2, 5, 3, 7, 101, 18};

    cout << LIS(arr);

    return 0;
}


