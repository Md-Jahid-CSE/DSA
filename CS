#include <bits/stdc++.h>
using namespace std;

int main() {

    vector<int> arr = {4, 2, 2, 8, 3, 3, 1};

    int n = arr.size();

    int maxVal = *max_element(arr.begin(), arr.end());

    vector<int> count(maxVal + 1, 0);

    for (int x : arr) {
        count[x]++;
    }

    for (int i = 1; i <= maxVal; i++) {
        count[i] += count[i - 1];
    }

    vector<int> output(n);

    for (int i = n - 1; i >= 0; i--) {
        int val = arr[i];
        int pos = count[val] - 1;

        output[pos] = val;
        count[val]--;
    }

    cout << "Sorted Array: ";
    for (int x : output)
        cout << x << " ";

    return 0;
}
